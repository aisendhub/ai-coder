# -------- Supabase (required) --------
# Find these at https://supabase.com/dashboard/project/<project-ref>/settings/api
# Public-safe — used by the Vite frontend.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Same URL as above but used by the Node/Hono backend.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# NEVER expose this in the browser. Used server-side to bypass RLS for system work.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -------- Anthropic (prod only) --------
# In local dev, leave this unset — the server deletes ANTHROPIC_API_KEY at startup
# so the Claude CLI falls back to subscription OAuth (run `claude /login` once).
# In production (Railway), set this to a real API key.
# ANTHROPIC_API_KEY=sk-ant-...

# -------- Integrations encryption (required) --------
# AES-256-GCM key for encrypting stored provider tokens (e.g. GitHub OAuth tokens).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INTEGRATIONS_KEY=base64-encoded-32-byte-key

# -------- Filesystem (optional, with defaults) --------
# Sandbox for the directory browser. Defaults to the parent of process.cwd()
# if unset. Projects must live under this path.
# PROJECTS_ROOT=/Users/you/code

# Where per-task git worktrees are created. Defaults to a sibling of PROJECTS_ROOT.
# WORKTREES_ROOT=/Users/you/code/.ai-coder-worktrees

# Workspace dir for temporary files (chat uploads, etc).
# WORKSPACE_DIR=/tmp/ai-coder

# -------- Server (optional, with defaults) --------
# HOST=0.0.0.0
# PORT=3001
# NODE_ENV=development
# SHELL=/bin/zsh

# -------- Runtime supervisor (optional) --------
# Cap on concurrently-running dev services per user.
# RUNTIME_MAX_SERVICES_PER_USER=10
# Port range for auto-assigned service ports.
# RUNTIME_PORT_RANGE=4000-4999
